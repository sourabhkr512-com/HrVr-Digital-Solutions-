# ─────────────────────────────────────────────────────────────
# HrVr Digital Solutions — Environment Variables (MongoDB)
# ─────────────────────────────────────────────────────────────
# 1. Is file ka naam .env karo (rename .env.example → .env)
# 2. Apna MONGO_URI daalo (local ya MongoDB Atlas)
# 3. Gmail App Password daalo

# ── MongoDB ──────────────────────────────────────
# Local MongoDB:
MONGO_URI=mongodb://localhost:27017/

# MongoDB Atlas (Cloud) example:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name
MONGO_DB=hrvr_digital

# ── Gmail App Password ───────────────────────────
# Steps:
#   1. myaccount.google.com → Security → 2-Step Verification ON karo
#   2. Search "App Passwords" → Mail select karo → 16-digit password milega
#   3. Woh password neeche daalo

MAIL_PASSWORD=jwoy ynop yedt bxwg
